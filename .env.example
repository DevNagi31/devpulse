# --- Postgres ---
DATABASE_URL=postgres://devpulse:devpulse@localhost:5432/devpulse

# Optional: override host port if 5432 is already in use locally.
# Set both this var AND DATABASE_URL above to the same port.
# POSTGRES_HOST_PORT=55433

# --- Redis (BullMQ) ---
REDIS_URL=redis://localhost:6379

# Optional: override host port if 6379 is already in use.
# REDIS_HOST_PORT=56379

# --- API ---
API_PORT=4000
SESSION_SECRET=change-me-in-prod-please-32-bytes-min
WEB_ORIGIN=http://localhost:5173

# --- GitHub OAuth ---
# Create at https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_CALLBACK=http://localhost:4000/auth/github/callback

# --- Groq (LLM) ---
# Free tier at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Web ---
VITE_API_URL=http://localhost:4000
